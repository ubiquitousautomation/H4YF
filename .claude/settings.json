{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/drive-sync.sh push 2>&1 | tail -8"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bash scripts/drive-sync.sh*)",
      "Bash(bash scripts/setup-drive.sh*)",
      "Bash(rclone*)"
    ]
  }
}
