{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 .claude/scripts/hooks.py session-start"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python3 .claude/scripts/hooks.py session-stop"
      }
    ]
  }
}
